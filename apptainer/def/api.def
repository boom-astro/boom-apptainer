Bootstrap: docker
From: rust:1.93.1-slim-trixie

%environment
    export PATH=/app:/opt/kafka/bin:$PATH
    # Optional overrides
    export BOOM_DATABASE__HOST=localhost

%files
    Cargo.toml /app/Cargo.toml
    Cargo.lock /app/Cargo.lock
    apache-avro-macros /app/apache-avro-macros
    data/models /app/data/models
    data/ls_footprint_moc.fits /app/data/ls_footprint_moc.fits
    src /app/src

%post
    KAFKA_VERSION=4.1.1
    SCALA_VERSION=2.13

    apt-get update && \
    apt-get install -y --no-install-recommends \
      curl gcc g++ libhdf5-dev libclang-dev perl \
      make libsasl2-dev pkg-config \
      libsasl2-2 ca-certificates default-jre-headless && \
    apt-get autoremove && apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install Kafka CLI tools (kafka-configs.sh, kafka-acls.sh) used by the API
    # to manage babamul Kafka users and ACLs.
    curl -fsSL "https://dlcdn.apache.org/kafka/${KAFKA_VERSION}/kafka_${SCALA_VERSION}-${KAFKA_VERSION}.tgz" -o /tmp/kafka.tgz && \
    tar -xzf /tmp/kafka.tgz -C /opt && \
    ln -s "/opt/kafka_${SCALA_VERSION}-${KAFKA_VERSION}" /opt/kafka && \
    rm -f /tmp/kafka.tgz

    cd /app || exit 1
    cargo build --release --bin api --bin add_filter

    cp /app/target/release/api /app/boom-api
    cp /app/target/release/add_filter /app/add_filter

    # Cleanup: remove build deps and artifacts to reduce image size
    apt-get purge -y gcc g++ libhdf5-dev libclang-dev perl make libsasl2-dev pkg-config
    apt-get autoremove -y
    apt-get clean
    rm -rf /app/target /app/src /app/apache-avro-macros /app/Cargo.toml /app/Cargo.lock
    rm -rf /root/.cargo /usr/local/cargo /usr/local/rustup
    rm -rf /var/lib/apt/lists/*