Bootstrap: docker
From: nvidia/cuda:12.8.1-cudnn-runtime-ubuntu24.04

%environment
    export PATH=/app:/opt/kafka/bin:/root/.cargo/bin:$PATH
    export LD_LIBRARY_PATH=/opt/ort:/usr/local/cuda/lib64:$LD_LIBRARY_PATH
    export ORT_DYLIB_PATH=/opt/ort/libonnxruntime.so
    # Optional overrides
    export BOOM_DATABASE__HOST=localhost

%files
    Cargo.toml /app/Cargo.toml
    Cargo.lock /app/Cargo.lock
    apache-avro-macros /app/apache-avro-macros
    data/models /app/data/models
    data/ls_footprint_moc.fits /app/data/ls_footprint_moc.fits
    src /app/src

%post
    KAFKA_VERSION=4.1.1
    SCALA_VERSION=2.13
    ONNXRUNTIME_GPU_VERSION=1.24.4
    RUST_VERSION=1.93.1
    export DEBIAN_FRONTEND=noninteractive

    apt-get update && \
    apt-get install -y --no-install-recommends \
      ca-certificates curl bash tar xz-utils \
      gcc g++ libhdf5-dev libclang-dev perl make \
      libsasl2-dev libsasl2-2 pkg-config \
      default-jre-headless \
      python3 python3-venv && \
    apt-get autoremove && apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install Rust toolchain (build only, removed at the end)
    curl -fsSL https://sh.rustup.rs | sh -s -- -y --profile minimal --default-toolchain ${RUST_VERSION}
    export PATH="/root/.cargo/bin:$PATH"

    # Install ONNX Runtime GPU shared libs via pip, then copy them to /opt/ort
    python3 -m venv /opt/ort-py
    /opt/ort-py/bin/pip install --no-cache-dir "onnxruntime-gpu==${ONNXRUNTIME_GPU_VERSION}"
    ORT_CAPI_DIR="$('/opt/ort-py/bin/python' -c 'import pathlib, onnxruntime as ort; print(pathlib.Path(ort.__file__).resolve().parent / "capi")')"
    mkdir -p /opt/ort
    cp "${ORT_CAPI_DIR}/libonnxruntime.so.${ONNXRUNTIME_GPU_VERSION}" /opt/ort/
    cp "${ORT_CAPI_DIR}/libonnxruntime_providers_cuda.so" /opt/ort/
    cp "${ORT_CAPI_DIR}/libonnxruntime_providers_shared.so" /opt/ort/
    cp "${ORT_CAPI_DIR}/libonnxruntime_providers_tensorrt.so" /opt/ort/
    ln -sf /opt/ort/libonnxruntime.so.${ONNXRUNTIME_GPU_VERSION} /opt/ort/libonnxruntime.so
    rm -rf /opt/ort-py

    # Install Kafka CLI tools
    curl -fsSL https://dlcdn.apache.org/kafka/${KAFKA_VERSION}/kafka_${SCALA_VERSION}-${KAFKA_VERSION}.tgz -o /tmp/kafka.tgz && \
    tar -xzf /tmp/kafka.tgz -C /opt && \
    ln -s /opt/kafka_${SCALA_VERSION}-${KAFKA_VERSION} /opt/kafka && \
    rm -f /tmp/kafka.tgz

    cd /app || exit 1
    cargo build --release

    cp /app/target/release/kafka_producer /app/kafka_producer
    cp /app/target/release/kafka_consumer /app/kafka_consumer
    cp /app/target/release/scheduler /app/scheduler
    cp /app/target/release/migrate_fp_flux /app/migrate_fp_flux
    cp /app/target/release/migrate_snr /app/migrate_snr

    # Cleanup: remove build deps and artifacts to reduce image size
    apt-get purge -y gcc g++ libhdf5-dev libclang-dev perl make libsasl2-dev pkg-config python3-venv
    apt-get autoremove -y
    apt-get clean
    rm -rf /app/target /app/src /app/apache-avro-macros /app/Cargo.toml /app/Cargo.lock
    rm -rf /root/.cargo /root/.rustup
    rm -rf /var/lib/apt/lists/*
