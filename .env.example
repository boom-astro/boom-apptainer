# Basic info
# Domain would be set to the production domain with an env var on deployment,
# e.g., boom.caltech.edu
DOMAIN=localhost
STACK_NAME=boom

# Database configuration (used by both Docker Compose and the BOOM application)
BOOM_DATABASE__USERNAME=mongoadmin
BOOM_DATABASE__PASSWORD=mongoadminsecret # Replace with something secure in production

# Cutout storage configuration.
# See README for the three cutout storage modes (shared mongo, dedicated mongo, S3).
#
# Shared mongo (make dev): no extra vars needed.
#
# Dedicated mongo (make dev-mongo):
#   Credentials below are used by both the mongo-cutouts container and
#   the boom services that connect to it.
BOOM_CUTOUTS_STORAGE__USERNAME=${BOOM_DATABASE__USERNAME}
BOOM_CUTOUTS_STORAGE__PASSWORD=${BOOM_DATABASE__PASSWORD}
#   Optional: host path for the dedicated mongo-cutouts data volume.
#   Leave unset to use a Docker-managed named volume (mongodb_cutouts).
# BOOM_CUTOUTS_MONGO_VOLUME=/mnt/large-disk/boom_cutouts
#
# S3/rustfs (make dev-s3):
#   Required credentials for the rustfs container and boom services.
BOOM_CUTOUTS_STORAGE__ACCESS_KEY=rustfsadmin
BOOM_CUTOUTS_STORAGE__SECRET_KEY=rustfsadminsecret # Replace with something secure in production
#   Optional: memory cap for the dedicated valkey-cutouts cache.
#   When full, keys with the shortest remaining TTL are evicted first (volatile-ttl).
# BOOM_CUTOUTS__CACHE__MAXMEMORY=1024mb

# API configuration (unified format)
BOOM_API__DOMAIN=localhost
BOOM_API__PORT=4000
BOOM_API__AUTH__SECRET_KEY=your-super-secret-jwt-key-at-least-32-chars-long # Replace with something secure in production
BOOM_API__AUTH__ADMIN_PASSWORD=adminsecret # Replace with something secure in production

# Kafka consumer configuration
BOOM_KAFKA__CONSUMER__ZTF__GROUP_ID=boom-ztf-consumer-group

BOOM_KAFKA__CONSUMER__LSST__GROUP_ID=boom-lsst-consumer-group
BOOM_KAFKA__CONSUMER__LSST__USERNAME=lsst_user
BOOM_KAFKA__CONSUMER__LSST__PASSWORD=lsst_password

BOOM_KAFKA__CONSUMER__DECAM__GROUP_ID=boom-decam-consumer-group

# Optional overrides (these have defaults in config.yaml)
# BOOM_DATABASE__NAME=boom
# BOOM_DATABASE__HOST=localhost
# BOOM_DATABASE__PORT=27017
# BOOM_API__AUTH__ADMIN_USERNAME=admin
# BOOM_API__AUTH__ADMIN_EMAIL=admin@yourcompany.com

# Prometheus config
PROMETHEUS_USER=prometheus
# This default password is simply 'prometheus' hashed using bcrypt
# For production, generate a secure bcrypt hash of your desired password
# Generate it using:
#    htpasswd -nbB prometheus 'your-password' | cut -d: -f2 | sed 's/\$/\$\$/g'
PROMETHEUS_HASHED_PASSWORD=$$2y$$05$$LWUC/TTh7NinSLdqn9eegO8cTvQp.SWuLgkcUy0rFeeq7Wc4t2i.G
PROMETHEUS_RETENTION_TIME=15d

# Kafka external read-only access (SASL/SCRAM)
# Required if exposing the EXTERNAL listener (port 9093) via Traefik or direct port mapping.
# Provide strong passwords; these are used by the init script to create/update users.
KAFKA_ADMIN_PASSWORD=change-me-admin
KAFKA_READONLY_PASSWORD=change-me-readonly
# Public hostname clients will use (overrides default localhost in advertised listeners for EXTERNAL)
# Set to your DNS name in production, e.g., kafka.boom.caltech.edu
# KAFKA_EXTERNAL_HOST=localhost

BOOM_GPU__ENABLED=false # Set to false to force CPU and avoid GPU library loading.
BOOM_GPU__DEVICE_IDS=0 # Comma-separated list of GPU device IDs to use (e.g., "0,1" for the first two GPUs)

# Babamul configuration
BOOM_BABAMUL__ENABLED=false
BOOM_BABAMUL__WEBAPP_URL="http://localhost:5173"

# Email configuration (for sending notifications and Babamul activation codes)
# Set EMAIL_ENABLED=true to send activation codes via email
# If disabled, activation codes will be printed to console logs
EMAIL_ENABLED=false
SMTP_SERVER=smtp.example.com
SMTP_USERNAME=boom_service
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_ADDRESS=boom@example.com

# Grafana configuration
GRAFANA_ADMIN_USER=grafanaadmin
GRAFANA_ADMIN_PASSWORD=ChangeMe!2024 # Must be strong (8+ chars, mixed case, numbers, symbols) per Grafana password policy

# Telegram Bot credentials
BOT_TOKEN=token_of_your_telegram_bot
BOOM_CHAT_ID=id_of_your_telegram_chat
BOOM_TESTING_CHAT_ID=id_of_your_telegram_testing_chat